# RLAPP - Variables de entorno locales para Docker Compose
# Copie este archivo a `.env` en la raíz del repositorio antes de ejecutar `docker compose`.

# Base de datos
POSTGRES_USER=rlapp
POSTGRES_PASSWORD=change-me-postgres-password
RLAPP_DB_NAME=rlapp_waitingroom

# RabbitMQ
RABBITMQ_DEFAULT_USER=rlapp
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
RABBITMQ_DEFAULT_VHOST=/

# Observabilidad y administración
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
SEQ_ADMIN_PASSWORD=change-me-seq-password
PGADMIN_DEFAULT_EMAIL=admin@rlapp.local
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
