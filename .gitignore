# -----------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.swp
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx
BenchmarkDotNet.Artifacts/
project.lock.json
project.fragment.lock.json
artifacts/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
dist/
build/
.cache/
.parcel-cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.js
.pnp

# -----------------------------------------------------------------------------
# Test outputs
# -----------------------------------------------------------------------------
playwright-report/
test-results/
coverage/
lcov.info
*.snap.tmp

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.idea/
*.code-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log

# -----------------------------------------------------------------------------
# Monitoring data
# -----------------------------------------------------------------------------
prometheus_data/
grafana_data/
seq_data/
pgadmin_data/
rabbitmq_data/
postgres_data/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
.venv/
venv/
.pytest_cache/

# -----------------------------------------------------------------------------
# Generated / temporary
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.swp
~$*
