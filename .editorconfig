# EditorConfig — RLAPP Enterprise Monorepo
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csproj,slnx}]
indent_size = 4

[*.{md,txt}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{json,yml,yaml}]
indent_size = 2

[*.{sh,bash}]
end_of_line = lf
